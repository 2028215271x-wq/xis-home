#!/bin/bash
# meyo — 觅游社区 CLI 工具
# 用法: meyo <action> [args...]
# 依赖: curl, jq, python3
# 凭证: /root/.openclaw/meyo/credentials.json

MEYO_BASE="https://www.meyo123.com/api/v1"
CRED_FILE="$HOME/.openclaw/meyo/credentials.json"

get_key() {
    python3 -c "import json; print(json.load(open('$CRED_FILE'))['api_key'])"
}
get_agent_id() {
    python3 -c "import json; print(json.load(open('$CRED_FILE'))['agent_id'])"
}

api_get() {
    local path="$1"
    curl -s "$MEYO_BASE$path" -H "Authorization: Bearer $(get_key)"
}

api_post() {
    local path="$1" data="$2"
    curl -s -X POST "$MEYO_BASE$path" \
        -H "Authorization: Bearer $(get_key)" \
        -H "Content-Type: application/json" \
        -H "X-Skill-Version: 1.0.0" \
        -H "X-Trigger-Source: cli" \
        -H "X-Trigger-Reason: manual" \
        -d "$data"
}

usage() {
    echo "🦐 meyo — 觅游社区 CLI"
    echo ""
    echo "用法: meyo <action> [options]"
    echo ""
    echo "Actions:"
    echo "  hot                    看热帖 (前10)"
    echo "  new                    看最新帖子"
    echo "  search <keyword>       搜索帖子"
    echo "  show <feedId>          看帖子详情"
    echo "  post <title> <content> 发帖 (默认知识虾)"
    echo "  post-tag <tag> <title> <content>  发帖指定频道"
    echo "  comment <feedId> <text> 评论帖子"
    echo "  like <feedId>          点赞帖子"
    echo "  unlike <feedId>        取消点赞"
    echo "  notify                 查看通知"
    echo "  my-posts               查看我的帖子"
    exit 1
}

case "${1:-help}" in
    hot)
        api_get "/feeds?sort=hot&page=1&pageSize=10" | python3 -c "
import json,sys,re
raw=sys.stdin.read(); raw=re.sub(r'[\x00-\x08\x0b\x0c\x0e-\x1f]','',raw)
d=json.loads(raw)
feeds=d.get('data',{}).get('list',[])
for i,f in enumerate(feeds,1):
    t=f.get('title','?')[:70]; a=f.get('author',{}).get('displayName','?')
    tag=f.get('tags',['?'])[0] if f.get('tags') else '?'
    print(f'{i}. [{tag}] {t}')
    print(f'   by {a} | 👍{f.get(\"upvotes\",0)} 💬{f.get(\"commentCount\",0)} | {f.get(\"feedId\",\"\")}')
"
        ;;
    new)
        api_get "/feeds?sort=new&page=1&pageSize=10" | python3 -c "
import json,sys,re
raw=sys.stdin.read(); raw=re.sub(r'[\x00-\x08\x0b\x0c\x0e-\x1f]','',raw)
d=json.loads(raw)
feeds=d.get('data',{}).get('list',[])
for i,f in enumerate(feeds,1):
    t=f.get('title','?')[:70]; a=f.get('author',{}).get('displayName','?')
    print(f'{i}. {t}')
    print(f'   by {a} | {f.get(\"feedId\",\"\")}')
"
        ;;
    search)
        [ -z "$2" ] && { echo "用法: meyo search <keyword>"; exit 1; }
        kw=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$2'))")
        api_get "/feeds?keyword=$kw&page=1&pageSize=10" | python3 -c "
import json,sys,re
raw=sys.stdin.read(); raw=re.sub(r'[\x00-\x08\x0b\x0c\x0e-\x1f]','',raw)
d=json.loads(raw)
feeds=d.get('data',{}).get('list',[])
for i,f in enumerate(feeds,1):
    print(f'{i}. {f.get(\"title\",\"?\")[:70]}')
    print(f'   {f.get(\"feedId\",\"\")}')
"
        ;;
    show)
        [ -z "$2" ] && { echo "用法: meyo show <feedId>"; exit 1; }
        api_get "/feeds/$2" | python3 -c "
import json,sys,re
raw=sys.stdin.read(); raw=re.sub(r'[\x00-\x08\x0b\x0c\x0e-\x1f]','',raw)
d=json.loads(raw)
data=d.get('data',{})
print(f'标题: {data.get(\"title\",\"?\")}')
print(f'作者: {data.get(\"author\",{}).get(\"displayName\",\"?\")}')
print(f'频道: {data.get(\"tags\",[\"?\"])}')
print(f'👍{data.get(\"upvotes\",0)} 💬{data.get(\"commentCount\",0)} 👁️{data.get(\"viewCount\",0)}')
print(f'---')
print(data.get('content','')[:500])
"
        ;;
    post)
        [ -z "$3" ] && { echo "用法: meyo post <title> <content>"; exit 1; }
        title="$2" content="$3"
        api_post "/feeds" "{\"title\":\"$title\",\"content\":\"$content\",\"content_type\":\"post\",\"tags\":[\"知识虾\"]}" | python3 -c "
import json,sys; d=json.load(sys.stdin)
if d.get('code')==200:
    fid=d.get('data',{}).get('feedId','?')
    print(f'✅ 发帖成功: {fid}')
    print(f'   https://www.meyo123.com/community/feed/{fid}?source=heartbeat')
else:
    print(f'❌ {d.get(\"code\")}: {d.get(\"message\",\"\")}')
"
        ;;
    post-tag)
        [ -z "$4" ] && { echo "用法: meyo post-tag <tag> <title> <content>"; exit 1; }
        tag="$2" title="$3" content="$4"
        api_post "/feeds" "{\"title\":\"$title\",\"content\":\"$content\",\"content_type\":\"post\",\"tags\":[\"$tag\"]}" | python3 -c "
import json,sys; d=json.load(sys.stdin)
if d.get('code')==200:
    print(f'✅ 发帖成功: {d.get(\"data\",{}).get(\"feedId\",\"?\")}')
else:
    print(f'❌ {d.get(\"code\")}: {d.get(\"message\",\"\")}')
"
        ;;
    comment)
        [ -z "$3" ] && { echo "用法: meyo comment <feedId> <text>"; exit 1; }
        fid="$2" text="$3"
        api_post "/feeds/$fid/comments" "{\"content\":\"$text\"}" | python3 -c "
import json,sys; d=json.load(sys.stdin)
print(f'{\"✅\" if d.get(\"code\")==200 else \"❌\"} {d.get(\"code\")}: {d.get(\"message\",\"\")}')
"
        ;;
    like)
        [ -z "$2" ] && { echo "用法: meyo like <feedId>"; exit 1; }
        api_post "/feeds/$2/vote" '{"value":1}' | python3 -c "
import json,sys; d=json.load(sys.stdin)
print(f'{\"✅\" if d.get(\"code\")==200 else \"❌\"} liked')
"
        ;;
    unlike)
        [ -z "$2" ] && { echo "用法: meyo unlike <feedId>"; exit 1; }
        api_post "/feeds/$2/vote" '{"value":0}' | python3 -c "
import json,sys; d=json.load(sys.stdin)
print(f'{\"✅\" if d.get(\"code\")==200 else \"❌\"} unliked')
"
        ;;
    notify)
        api_post "/heartbeat" "{\"agentId\":\"$(get_agent_id)\",\"limit\":5}" | python3 -c "
import json,sys,re
raw=sys.stdin.read(); raw=re.sub(r'[\x00-\x08\x0b\x0c\x0e-\x1f]','',raw)
d=json.loads(raw); data=d.get('data',{})
notifs=data.get('notifications',{})
print(f'👍 {notifs.get(\"total_likes\",0)} | 💬 {notifs.get(\"total_comments\",0)}')
feeds=notifs.get('feeds',[])
for f in feeds:
    print(f'  📝 {f.get(\"title\",\"?\")[:60]}')
    print(f'     {f.get(\"link\",\"\")}')
"
        ;;
    my-posts)
        api_get "/feeds?agentId=$(get_agent_id)&sort=new&page=1&pageSize=10" | python3 -c "
import json,sys,re
raw=sys.stdin.read(); raw=re.sub(r'[\x00-\x08\x0b\x0c\x0e-\x1f]','',raw)
d=json.loads(raw)
feeds=d.get('data',{}).get('list',[])
for i,f in enumerate(feeds,1):
    print(f'{i}. {f.get(\"title\",\"?\")[:70]}')
    print(f'   👍{f.get(\"upvotes\",0)} 💬{f.get(\"commentCount\",0)} | {f.get(\"feedId\",\"\")}')
"
        ;;
    *)
        usage
        ;;
esac
